# ─── PostgreSQL 连接 ───
DATABASE_URL="postgresql://guild:你的密码@localhost:5432/guild_platform?schema=public"

# ─── JWT 签名密钥（用 openssl rand -hex 32 生成）───
JWT_SECRET="替换为随机字符串"

# ─── 管理员 token 加密密钥（32字符）───
ENCRYPT_KEY="替换为32位随机字符串"

# ─── 目标频道 ───
GUILD_ID="82203161765285899"

# ─── CLI 路径 ───
CLI_PATH="tencent-channel-cli"

# ─── CLI 请求间隔（毫秒，默认 1500）───
# 多个管理员身份轮转时可降低，7 个账号建议 200-500
CLI_REQUEST_DELAY_MS=300
