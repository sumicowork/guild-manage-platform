generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 帖子 ───
model Feed {
  id              BigInt    @id @default(autoincrement())
  feed_id         String    @unique
  author          String?
  author_id       String?
  channel_name    String?
  channel_id      String?
  title           String?
  content         String?
  content_snippet String?
  share_url       String?
  images          Json?
  prefer_count    Int       @default(0)
  comment_count   Int       @default(0)
  feed_type       Int?
  create_time     DateTime?
  create_time_raw BigInt?
  status          String    @default("active")
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  comments   Comment[]
  replies    Reply[]
  violations Violation[] @relation("ViolationFeed")

  @@index([author_id])
  @@index([channel_name])
  @@index([status])
  @@index([create_time])
  @@index([create_time_raw])
  @@map("feeds")
}

// ─── 评论 ───
model Comment {
  id              BigInt    @id @default(autoincrement())
  comment_id      String    @unique
  feed_id         String
  author          String?
  author_id       String?
  content         Json?
  content_text    String?
  like_count      Int       @default(0)
  reply_count     Int       @default(0)
  comment_index   Int?
  create_time     DateTime?
  create_time_raw BigInt?
  status          String    @default("active")
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  feed       Feed    @relation(fields: [feed_id], references: [feed_id])
  replies    Reply[]
  violations Violation[] @relation("ViolationComment")

  @@index([feed_id])
  @@index([author_id])
  @@index([status])
  @@index([create_time])
  @@map("comments")
}

// ─── 回复 ───
model Reply {
  id              BigInt    @id @default(autoincrement())
  reply_id        String    @unique
  comment_id      String
  feed_id         String
  author          String?
  author_id       String?
  content         Json?
  content_text    String?
  target_reply_id String?
  target_user     String?
  target_user_id  String?
  create_time     DateTime?
  create_time_raw BigInt?
  status          String    @default("active")
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  feed       Feed    @relation(fields: [feed_id], references: [feed_id])
  comment    Comment @relation(fields: [comment_id], references: [comment_id])
  violations Violation[] @relation("ViolationReply")

  @@index([comment_id])
  @@index([feed_id])
  @@index([author_id])
  @@index([status])
  @@map("replies")
}

// ─── 成员 ───
model Member {
  id              BigInt    @id @default(autoincrement())
  tinyid          String    @unique
  nickname        String?
  global_nickname String?
  avatar_seq      String?
  role            String?
  country         String?
  city            String?
  gender          String?
  join_time       DateTime?
  join_time_human String?
  status          String    @default("active")
  left_at         DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tags       MemberTag[]
  violations Violation[] @relation("ViolationTarget")

  @@index([status])
  @@index([nickname])
  @@index([join_time])
  @@map("members")
}

// ─── 用户标签 ───
model MemberTag {
  id         BigInt   @id @default(autoincrement())
  member_id  BigInt
  tag        String
  created_by BigInt?
  created_at DateTime @default(now())

  member Member @relation(fields: [member_id], references: [id])

  @@unique([member_id, tag])
  @@map("member_tags")
}

// ─── 违规记录 ───
model Violation {
  id                  BigInt    @id @default(autoincrement())
  target_type         String
  target_id           String
  target_feed_id      String?
  target_comment_id   String?
  target_reply_id     String?
  target_author       String?
  target_author_id    String?
  violation_reason    String
  violation_detail    String?
  action_type         String
  action_detail       Json?
  notification_sent   Boolean   @default(false)
  notification_type   String?
  notification_text   String?
  operator_user_id    BigInt
  operator_admin_id   String?
  operator_admin_name String?
  created_at          DateTime  @default(now())

  feed    Feed?    @relation("ViolationFeed", fields: [target_feed_id], references: [feed_id])
  comment Comment? @relation("ViolationComment", fields: [target_comment_id], references: [comment_id])
  reply   Reply?   @relation("ViolationReply", fields: [target_reply_id], references: [reply_id])
  member  Member?  @relation("ViolationTarget", fields: [target_author_id], references: [tinyid])
  user    PlatformUser @relation(fields: [operator_user_id], references: [id])

  @@index([target_type])
  @@index([violation_reason])
  @@index([created_at])
  @@index([operator_user_id])
  @@index([target_author_id])
  @@index([target_feed_id])
  @@index([target_comment_id])
  @@index([target_reply_id])
  @@index([target_id])
  @@map("violations")
}

// ─── 违规原因配置 ───
model ViolationReason {
  id                    BigInt   @id @default(autoincrement())
  name                  String   @unique
  is_builtin            Boolean  @default(false)
  notification_template String?
  sort_order            Int      @default(0)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@map("violation_reasons")
}

// ─── 平台用户 ───
model PlatformUser {
  id           BigInt   @id @default(autoincrement())
  username     String   @unique
  password     String
  display_name String?
  role         String   @default("operator")
  status       String   @default("active") // active | pending | disabled
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  violations   Violation[]
  refreshTokens RefreshToken[]

  @@map("platform_users")
}

// ─── Refresh Token（可撤销的续期令牌） ───
model RefreshToken {
  id          BigInt   @id @default(autoincrement())
  token_hash  String   @unique // SHA-256 哈希，仅存哈希防止数据库泄露后可复用
  user_id     BigInt
  expires_at  DateTime
  revoked_at  DateTime? // 非空 = 已撤销（注销或被新 token 替换）
  created_at  DateTime @default(now())

  user PlatformUser @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_tokens")
}

// ─── 频道管理员身份 ───
model AdminIdentity {
  id            BigInt    @id @default(autoincrement())
  nickname      String
  token         String
  token_expires DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@map("admin_identities")
}

// ─── 爬取任务 ───
model CrawlTask {
  id                BigInt    @id @default(autoincrement())
  task_type         String
  status            String    @default("pending")
  triggered_by      String    @default("manual")
  triggered_by_user BigInt?
  started_at        DateTime?
  finished_at       DateTime?
  stats             Json?
  error_log         String?
  created_at        DateTime  @default(now())

  @@index([status])
  @@index([task_type])
  @@map("crawl_tasks")
}

// ─── 自动处置规则 ───
model AutoRule {
  id                BigInt    @id @default(autoincrement())
  name              String                        // 规则名称
  target_author_id  String                        // 目标作者 tinyid
  action            String    @default("delete")  // "delete" | "move"
  target_channel_id String?                       // 移帖目标版块ID（action=move 时必填）
  enabled           Boolean   @default(true)      // 是否启用
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([target_author_id])
  @@index([enabled])
  @@map("auto_rules")
}

// ─── 操作日志（审计追踪） ───
model OperationLog {
  id            BigInt   @id @default(autoincrement())
  action        String   // e.g. "violation.delete"
  target_type   String   // e.g. "violation"
  target_id     String   // 被操作对象的 ID
  snapshot      Json?    // 操作前对象的快照（用于审计回溯）
  operator_id   BigInt   // 平台用户 ID
  operator_name String?  // 操作者用户名（冗余，便于查询）
  detail        String?  // 附加说明
  created_at    DateTime @default(now())

  @@index([action])
  @@index([target_type, target_id])
  @@index([operator_id])
  @@index([created_at])
  @@map("operation_logs")
}
